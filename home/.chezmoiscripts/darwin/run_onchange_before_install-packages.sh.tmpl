#!/bin/bash

set -eufo pipefail

{{ $brews := list
    "atuin"
    "mise"
    "ansible"
    "autoconf"
    "uv"
    "borgbackup"
    "bat"
    "curl"
    "direnv"
    "docker"
    "gleam"
    "goose"
    "fd"
    "flyctl"
    "fzf"
    "gh"
    "git"
    "helm"
    "imagemagick"
    "jj"
    "jq"
    "just"
    "libdvdcss"
    "kubernetes-cli"
    "openjdk"
    "neovim"
    "neonctl"
    "ripgrep"
    "rclone"
    "sqlc"
    "starship"
    "anomalyco/tap/opencode"
    "hashicorp/tap/packer"
    "hashicorp/tap/terraform"
    "siderolabs/tap/talosctl"
    "tmux"
    "tree-sitter-cli"
    "wget"
    "xz" -}}

{{ $casks := list
    "raspberry-pi-imager"
    "keepingyouawake"
    "ghostty"
    "copilot-cli"
    "lm-studio"
    "tailscale-app"
    "temurin@25"
    "discord"
    "obsidian"
    "jetbrains-toolbox"
    "visual-studio-code"
    "font-hack-nerd-font"
    "zed"
    "1password"
    "1password-cli" -}}


brew bundle --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF
